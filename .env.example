# Jailbroken iPhone SSH target used by scripts/deploy.sh and camera-mode helpers.
DEVICE_IP=192.168.1.50
DEVICE_USER=root
DEVICE_PASS=alpine

# Optional Theos checkout. If omitted, scripts/build.sh checks ./theos, ~/theos,
# /opt/theos, and /tmp/theos.
# THEOS=/opt/theos

# Optional Scrypted settings. DEVICE_IP is used as the camera host if
# IPHONE_SECURITYCAM_HOST is omitted. If both are omitted, the Scrypted helper
# tries Bonjour discovery via _oldiphonecam._tcp.
SCRYPTED_HOST=127.0.0.1:10443
IPHONE_SECURITYCAM_NAME=iPhone SE SecurityCam
# IPHONE_SECURITYCAM_HOST=192.168.1.50
